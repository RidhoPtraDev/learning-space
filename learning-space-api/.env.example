# Salin file ini ke .env dan isi semua nilai yang diperlukan.
# JANGAN COMMIT .env ke repository (sudah ada di .gitignore).

# ── Database (MySQL) ───────────────────────────────────────────────
DB_NAME=learning_space
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ── JWT ────────────────────────────────────────────────────────────
# Ganti dengan string random minimal 32 karakter (misal: openssl rand -hex 32)
JWT_SECRET=ganti_dengan_string_random_minimal_32_karakter

# ── Server ─────────────────────────────────────────────────────────
PORT=5000

# ── Gmail SMTP (untuk kirim email OTP) ────────────────────────────
# EMAIL_USER = alamat Gmail yang dipakai kirim email
# EMAIL_PASS = Google App Password (bukan password Gmail biasa)
# Cara buat App Password: https://support.google.com/accounts/answer/185833
EMAIL_USER=email_gmail_kamu@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# ── Google OAuth (opsional, belum aktif dipakai) ──────────────────
GOOGLE_CLIENT_ID=
